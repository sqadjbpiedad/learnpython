n': ['Central Luzon', 'Cagayan Valley', 'Western Visayas', 'Bicol', 'Ilocos'],\n    'Production_MT': [350000, 280000, 210000, 150000, 180000]\n}\ndf_crops = pd.DataFrame(data)\n\n# Sort the data\ndf_sorted = df_crops.sort_values('Production_MT', ascending=False)\n\n# Plot\nplt.figure(figsize=(10, 6))\n# orient='h' makes it horizontal\nsns.barplot(x='Production_MT', y='Region', data=df_sorted, color='teal')\n\n# Polish\nplt.title(\"Central Luzon leads in Palay Production\", loc='left', fontsize=14, fontweight='bold')\nplt.xlabel(\"Metric Tons\")\nplt.show()","visibility":"show","key":"UoJZsUSnol"},{"type":"outputs","id":"L1BhDT8B9Qe4b3AKvHXJG","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"9bd176c2845211e61f1006509be33573","path":"/learnpython/build/9bd176c2845211e61f1006509be33573.png"},"text/plain":{"content":"<Figure size 1000x600 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"LBLHikm3Fv"}],"visibility":"hide","key":"hZKUkaePTo"}],"visibility":"show","key":"TlvtAOPQqW"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Distributions","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"J0lDG1z9oT"}],"identifier":"distributions","label":"Distributions","html_id":"distributions","implicit":true,"key":"qXNfWaicxK"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"To show the true shape of data, we use histograms with a ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"dU4MuFz9lI"},{"type":"strong","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Kernel Density Estimate (KDE)","position":{"start":{"line":2,"column":1},"end":{"line