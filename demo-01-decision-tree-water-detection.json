 set to: {RANDOM_STATE}\")\nprint(f\"✓ NumPy version: {np.__version__}\")\nprint(f\"✓ Rasterio version: {rasterio.__version__}\")","identifier":"w1ggs5iknaep-code","enumerator":"1","html_id":"w1ggs5iknaep-code","key":"Lxr2rUKjdK"},{"type":"outputs","id":"1iKZrpu_BniIvLi5PuBBQ","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"✓ Libraries imported successfully!\n✓ Random state set to: 42\n✓ NumPy version: 2.0.2\n✓ Rasterio version: 1.4.4\n"},"children":[],"identifier":"w1ggs5iknaep-outputs-0","html_id":"w1ggs5iknaep-outputs-0","key":"tBb6kYs1rJ"}],"identifier":"w1ggs5iknaep-outputs","html_id":"w1ggs5iknaep-outputs","key":"QsNF3mAZhH"}],"identifier":"w1ggs5iknaep","label":"W1gGs5IknAEP","html_id":"w1ggs5iknaep","key":"ZajRU1dlrM"},{"type":"block","kind":"notebook-content","data":{"editable":true,"id":"w40559ipnAER","slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MJmuXlzIfL"},{"type":"heading","depth":2,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"B. Decision Trees Interactive Demo","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"SqAUqcdah8"}],"identifier":"b-decision-trees-interactive-demo","label":"B. Decision Trees Interactive Demo","html_id":"b-decision-trees-interactive-demo","implicit":true,"key":"SHOFkOlOzy"},{"type":"heading","depth":3,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"What is a Decision Tree?","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"LNadHypqCj"}],"identifier":"what-is-a-decision-tree","label":"What is a Decision Tree?","html_id":"what-is-a-decision-tree","implicit":true,"key":"FYUv2G8TtC"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"