 set to: {RANDOM_STATE}\")\nprint(f\"✓ NumPy version: {np.__version__}\")\nprint(f\"✓ Rasterio version: {rasterio.__version__}\")","identifier":"w1ggs5iknaep-code","enumerator":"1","html_id":"w1ggs5iknaep-code","key":"IJg2HURUGE"},{"type":"outputs","id":"PuplBB7HtfmrA-zgN2SN4","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"✓ Libraries imported successfully!\n✓ Random state set to: 42\n✓ NumPy version: 2.0.2\n✓ Rasterio version: 1.4.4\n"},"children":[],"identifier":"w1ggs5iknaep-outputs-0","html_id":"w1ggs5iknaep-outputs-0","key":"SAjdYzD5v1"}],"identifier":"w1ggs5iknaep-outputs","html_id":"w1ggs5iknaep-outputs","key":"j8qIWLCyAh"}],"identifier":"w1ggs5iknaep","label":"W1gGs5IknAEP","html_id":"w1ggs5iknaep","key":"X7gzmhSKYE"},{"type":"block","kind":"notebook-content","data":{"editable":true,"id":"w40559ipnAER","slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NZ9iMbz96r"},{"type":"heading","depth":2,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"B. Decision Trees Interactive Demo","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wylPq0hZ9C"}],"identifier":"b-decision-trees-interactive-demo","label":"B. Decision Trees Interactive Demo","html_id":"b-decision-trees-interactive-demo","implicit":true,"key":"Rdq0hMtDrj"},{"type":"heading","depth":3,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"What is a Decision Tree?","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"NnyNuzYsd0"}],"identifier":"what-is-a-decision-tree","label":"What is a Decision Tree?","html_id":"what-is-a-decision-tree","implicit":true,"key":"SPI9V1mNnH"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"