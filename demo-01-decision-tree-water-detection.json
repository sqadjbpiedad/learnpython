type":"list","ordered":false,"spread":false,"position":{"start":{"line":6,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Used for delineating and monitoring content changes in surface water","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"aaPpK5MIUH"}],"key":"iCTiwUO8Z4"}],"key":"ukwg8ocmHO"},{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Formula:   NDWI = (Green + NIR) / (Green − NIR)","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"NzgnJGqKfU"}],"key":"FH6a0Xve3k"}],"key":"DsgrKLrJYW"}],"key":"aAGURttOvR"}],"visibility":"show","key":"RJtMNhBNNf"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/"},"id":"zVGS2YUP3QTs","outputId":"cbbe09de-4d61-4066-c55a-8e8fa7c3da9a"},"children":[{"type":"code","lang":"python","executable":true,"value":"# Load Data\nfile_path = \"test_image.tif\"\n\nwith rasterio.open(file_path) as src:\n    # Read and flatten bands\n    green = src.read(2).flatten()\n    red   = src.read(3).flatten()\n    nir   = src.read(4).flatten()\n\n    # Store metadata for reconstruction\n    height, width = src.height, src.width\n    rgb_raw = src.read([4, 3, 2])\n\n# Generate Proxy Labels (Ground Truth)\nndwi_label = (green - nir) / (green + nir + 1e-6)\nndvi_label = (nir - red) / (nir + red + 1e-6)\n\n# Create binary water mask: High NDWI AND Low NDVI\ny_water_proxy = np.zeros_like(ndwi_label)\ny_water_proxy[(ndwi_label > 0.0) & (ndvi_label < 0.2)] = 1\n\nprint(f\"✓ Image Dimensions: {height}x{width}\")\nprint(f\"✓ Total Pixels: {len(ndwi_label)}\")\nprint(f\"✓ Proxy Water Pixels: {int(np.sum(y_water_proxy))}\")","identifier":"zvgs2yup3qts-code","enumerator":"3","html_id":"zvgs2yup3qts-code","key":"gPk8JIQmKI"},{"type":"outputs","id":"GBmEIjKkxhrfTMO5W0Wjw","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"✓ Image Dimensions: 74x76\n✓ Total Pixels: 5624\n✓ Proxy Water Pixels: 3229\n"},"children":[],"identifier":"zvgs2yup3qts-outputs-0","html_id":"zvgs2yup3qts-outputs-0","key":"eRb8skWRZR"}],"identifier":"zvgs2yup3qts-outputs","html_id":"zvgs2yup3qts-outputs","key":"O4uBYIBMVH"}],"identifier":"zvgs2yup3qts","label":"zVGS2YUP3QTs","html_id":"zvgs2yup3qts","key":"c9xjU1S8vM"},{"type":"block","kind":"notebook-content","data":{"editable":true,"id":"6uaTeNpW6dAx","slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"heading","depth":4,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"2. Model Training and Prediction","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"TpPzCJZtS0"}],"identifier":"id-2-model-training-and-prediction","label":"2. Model Training and Prediction","html_id":"id-2-model-training-and-prediction","implicit":true,"key":"Z6LEaVeF6K"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"We will now train a Decision Tree classifier to recognize “water” based on the spectral signatures of the Green, Red, and NIR bands.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"hZNQTFR9Fz"}],"key":"wtIw6roKAq"}],"identifier":"6uatenpw6dax","label":"6uaTeNpW6dAx","html_id":"id-6uatenpw6dax","visibility":"show","key":"wCZNPHnIlY"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/"},"id":"tPNHNGTr7TrM","outputId":"ade93659-8e25-4906-9746-e00c30cbde4e"},"children":[{"type":"code","lang":"python","executable":true,"value":"# Prepare Training Data\n\n# Filter out invalid (zero) pixels to improve training quality\nvalid_mask = (red > 0) & (nir > 0) & (green > 0)\nX = np.stack([green[valid_mask], red[valid_mask], nir[valid_mask]], axis=1)\ny = y_water_proxy[valid_mask]\n\n# Data Inspection\nprint(\"📊 Dataset Statistics:\")\nprint(\"━\" * 30)\nprint(f\"Dataset shape:      {X.shape} (Pixels, Bands)\")\nprint(f\"Number of samples:  {X.shape[0]}\")\nprint(f\"Number of features: {X.shape[1]} (Green, Red, NIR)\")\nprint(f\"Classes:            {np.unique(y)} (0: Non-water, 1: Water)\")\n\n# Calculate distribution\ncounts = np.bincount(y.astype(int))\nprint(f\"Class distribution: Non-Water: {counts[0]}, Water: {counts[1]}\")\nprint(\"━\" * 30)\n\n# Split data\nX_train, X_test, y_train, y_test = train_test_split(\n    X, y, random_state=RANDOM_STATE\n)","identifier":"tpnhngtr7trm-code","enumerator":"4","html_id":"tpnhngtr7trm-code","key":"peYOQq7gcB"},{"type":"outputs","id":"A1F4Gt0CpM4CQxvm8gcge","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"📊 Dataset Statistics:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nDataset shape:      (5624, 3) (Pixels, Bands)\nNumber of samples:  5624\nNumber of features: 3 (Green, Red, NIR)\nClasses:            [0. 1.] (0: Non-water, 1: Water)\nClass distribution: Non-Water: 2395, Water: 3229\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"},"children":[],"identifier":"tpnhngtr7trm-outputs-0","html_id":"tpnhngtr7trm-outputs-0","key":"jlxL4Se7Cr"}],"identifier":"tpnhngtr7trm-outputs","html_id":"tpnhngtr7trm-outputs","key":"MZqNnrG2dZ"}],"identifier":"tpnhngtr7trm","label":"tPNHNGTr7TrM","html_id":"tpnhngtr7trm","key":"qcWzrTYrVW"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/"},"id":"9qzCMYYQ7g7l","outputId":"fee01f9e-570d-4f52-c4b1-2cb06030b999"},"children":[{"type":"code","lang":"python","executable":true,"value":"# Train Model\nwater_model = DecisionTreeClassifier(max_depth=3, random_state=RANDOM_STATE)\nwater_model.fit(X_train, y_train)\n\n# Evaluation Metrics\ntrain_accuracy = water_model.score(X_train, y_train)\ntest_accuracy = water_model.score(X_test, y_test) # Checking against unseen data\n\nprint(f\"📊 Model Performance:\")\nprint(f\"✓ Training Accuracy: {train_accuracy:.3f}\")\nprint(f\"✓ Tree Depth:       {water_model.get_depth()}\")\nprint(f\"✓ Number of Leaves: {water_model.get_n_leaves()}\")\n\n# Generate Map for the entire image\nX_full = np.stack([green, red, nir], axis=1)\npredictions = water_model.predict(np.nan_to_num(X_full))\nwater_map = predictions.reshape(height, width)\n\nprint(f\"✓ Full image prediction complete.\")","identifier":"9qzcmyyq7g7l-code","enumerator":"5","html_id":"id-9qzcmyyq7g7l-code","key":"mG7wiqYQJc"},{"type":"outputs","id":"yn74VwU0JlJ0jxgNdEV5f","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"📊 Model Performance:\n✓ Training Accuracy: 0.984\n✓ Tree Depth:       3\n✓ Number of Leaves: 7\n✓ Full image prediction complete.\n"},"children":[],"identifier":"9qzcmyyq7g7l-outputs-0","html_id":"id-9qzcmyyq7g7l-outputs-0","key":"YCcq6ztSNr"}],"identifier":"9qzcmyyq7g7l-outputs","html_id":"id-9qzcmyyq7g7l-outputs","key":"PhykwO4N8x"}],"identifier":"9qzcmyyq7g7l","label":"9qzCMYYQ7g7l","html_id":"id-9qzcmyyq7g7l","key":"MOXzCf4oEm"},{"type":"block","kind":"notebook-content","data":{"editable":true,"id":"Cl81JeTc711n","slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"heading","depth":4,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3. Visualization and Results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MhNJ6xyAWW"}],"identifier":"id-3-visualization-and-results","label":"3. Visualization and Results","html_id":"id-3-visualization-and-results","implicit":true,"key":"NJYkYYpEqt"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Finally, we compare our predicted water map against the True Color (RGB) reference image to evaluate the model’s performance.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"jdYJ17cFlN"}],"key":"dmelYr6YNV"}],"identifier":"cl81jetc711n","label":"Cl81JeTc711n","html_id":"cl81jetc711n","visibility":"show","key":"L4epkgMSJ5"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/","height":512},"editable":true,"id":"sZEe3Qor72IF","outputId":"b2b43945-3bca-41cf-d2d0-7bac1af44f00","slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# Visualization\nfig, (ax1, ax2) = plt.subplots(1, 2, figsize=(20, 10), sharex=True, sharey=True)\n\n# Plot 1: RGB Reference\n# Perform a 2% linear stretch for better visualization\nrgb = rgb_raw.transpose(1, 2, 0).astype(float)\np2, p98 = np.percentile(rgb, (2, 98))\nrgb_stretched = np.clip((rgb - p2) / (p98 - p2), 0, 1)\n\nax1.imshow(rgb_stretched)\nax1.set_title(\"True Color (RGB) Reference\", fontsize=15, fontweight='bold')\nax1.axis('off')\n\n# Plot 2: Water Map\nwater_cmap = ListedColormap(['#f0f0f0', '#00008b']) # Light grey and Deep Blue\nim = ax2.imshow(water_map, cmap=water_cmap)\nax2.set_title(\"Water Detection Map (Decision Tree)\", fontsize=15, fontweight='bold')\nax2.axis('off')\n\n# Add Legend\ncbar = plt.colorbar(im, ax=ax2, ticks=[0.25, 0.75], fraction=0.046, pad=0.04)\ncbar.ax.set_yticklabels(['Non-Water', 'Water'])\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n💡 TIP: Decision Trees are great for EO because they create clear 'if-then' rules\")\nprint(\"based on spectral thresholds, making the classification process easy to interpret.\")","identifier":"szee3qor72if-code","visibility":"show","enumerator":"6","html_id":"szee3qor72if-code","key":"H6lpJbbXaH"},{"type":"outputs","id":"FRF7Ob4eslVKPEldFR9pi","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"38f2e67ff5433588f70c04c24a32230b","path":"/learnpython//build/38f2e67ff5433588f70c04c24a32230b.png"},"text/plain":{"content":"<Figure size 2000x1000 with 3 Axes>","content_type":"text/plain"}}},"children":[],"identifier":"szee3qor72if-outputs-0","html_id":"szee3qor72if-outputs-0","key":"oNNGC9jPed"},{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\n💡 TIP: Decision Trees are great for EO because they create clear 'if-then' rules\nbased on spectral thresholds, making the classification process easy to interpret.\n"},"children":[],"identifier":"szee3qor72if-outputs-1","html_id":"szee3qor72if-outputs-1","key":"Bz28bck8UW"}],"identifier":"szee3qor72if-outputs","visibility":"show","html_id":"szee3qor72if-outputs","key":"qQGQ6lzdf9"}],"identifier":"szee3qor72if","label":"sZEe3Qor72IF","html_id":"szee3qor72if","visibility":"show","key":"tOdLyTh6PH"},{"type":"block","kind":"notebook-content","data":{"editable":true,"id":"uU9RVevTnAES","slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visualize the Tree Structure","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ayscl68LZO"}],"identifier":"visualize-the-tree-structure","label":"Visualize the Tree Structure","html_id":"visualize-the-tree-structure","implicit":true,"key":"yFkiM5RS8o"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Let’s look inside the tree to see the actual decision rules it learned.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"H1Zv91TMfL"}],"key":"gOnSJsV15k"}],"identifier":"uu9rvevtnaes","label":"uU9RVevTnAES","html_id":"uu9rvevtnaes","visibility":"show","key":"ZR8EFLuejb"},{"type":"block","kind":"notebook-code","data":{"colab":{"base_uri":"https://localhost:8080/","height":610},"id":"xnVSWwtXnAES","outputId":"5dc2fec7-1fab-4303-c4cc-cf01f67d150b"},"children":[{"type":"code","lang":"python","executable":true,"value":"from sklearn.tree import plot_tree\n\n# Configure the visual parameters\nplt.figure(figsize=(25, 12)) # Wider figure for better readability\n\n# Plot the tree structure\n# Note: We limit max_depth to 3 for the visualization so it stays readable\nplot_tree(water_model,\n         feature_names=['Green Reflectance', 'Red Reflectance', 'NIR Reflectance'],\n         class_names=['Non-Water', 'Water'],\n         max_depth=3,\n         filled=True,\n         rounded=True,\n         fontsize=12,\n         precision=2)\n\nplt.title('Decision Tree Structure: Learned Spectral Rules', fontsize=20, fontweight='bold', pad=20)\nplt.tight_layout()\nplt.show()\n\nprint(\"\\nHow to Read This Tree:\")\nprint(\"━\" * 60)\nprint(\"• Each box is a node with a decision rule (e.g., 'NIR <= 120.5')\")\nprint(\"• 'gini' measures impurity (0 = pure, 0.5 = mixed)\")\nprint(\"• 'samples' shows how many training pixels reach this node\")\nprint(\"• 'value' shows pixel distribution [Non-Water, Water]\")\nprint(\"• Color intensity indicates class majority (darker Blue = Water, darker Orange = Non-Water)\")\nprint(\"• Leaf nodes (bottom) make the final classification for your map\")","identifier":"xnvswwtxnaes-code","enumerator":"7","html_id":"xnvswwtxnaes-code","key":"YW0Sa6EdMb"},{"type":"outputs","id":"buOPxeq9F6Lp05kVmGFlB","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"5f6172978ce251a65fdcc92516d3c57e","path":"/learnpython//build/5f6172978ce251a65fdcc92516d3c57e.png"},"text/plain":{"content":"<Figure size 2500x1200 with 1 Axes>","content_type":"text/plain"}}},"children":[],"identifier":"xnvswwtxnaes-outputs-0","html_id":"xnvswwtxnaes-outputs-0","key":"hhOjfoW309"},{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\nHow to Read This Tree:\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n• Each box is a node with a decision rule (e.g., 'NIR <= 120.5')\n• 'gini' measures impurity (0 = pure, 0.5 = mixed)\n• 'samples' shows how many training pixels reach this node\n• 'value' shows pixel distribution [Non-Water, Water]\n• Color intensity indicates class majority (darker Blue = Water, darker Orange = Non-Water)\n• Leaf nodes (bottom) make the final classification for your map\n"},"children":[],"identifier":"xnvswwtxnaes-outputs-1","html_id":"xnvswwtxnaes-outputs-1","key":"UuV3G2oi2a"}],"identifier":"xnvswwtxnaes-outputs","html_id":"xnvswwtxnaes-outputs","key":"sbafiR0Wy6"}],"identifier":"xnvswwtxnaes","label":"xnVSWwtXnAES","html_id":"xnvswwtxnaes","key":"dNCSPsvPAP"},{"type":"block","kind":"notebook-content","data":{"editable":true,"id":"fz-tooNHnAEV","slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"thematicBreak","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"L4qUTTwi7V"},{"type":"heading","depth":2,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Summary and Key Takeaways","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"D9hdvVO3dV"}],"identifier":"summary-and-key-takeaways","label":"Summary and Key Takeaways","html_id":"summary-and-key-takeaways","implicit":true,"key":"I0LBtW7xJh"},{"type":"heading","depth":3,"position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Decision Trees","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"A2MrMuIJ9M"}],"identifier":"decision-trees","label":"Decision Trees","html_id":"decision-trees","implicit":true,"key":"zCxZ4cAhsR"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":6,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Learn 