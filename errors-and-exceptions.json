rea to float\n                area = float(parts[2])\n                print(f\"Farm {farm_id} ({crop}): {area} ha\")\n            except ValueError:\n                print(f\"Warning: Invalid area for Farm {farm_id}\")\n\nexcept FileNotFoundError:\n    print(f\"Critical Error: The file '{target_file}' was not found.\")","visibility":"show","key":"tFEx7S8Xa7"},{"type":"outputs","id":"VjM5ZY_ZXpmsOrKIHO3xx","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Critical Error: The file 'missing_file.txt' was not found.\n"},"children":[],"key":"fhICoXomcY"}],"visibility":"hide","key":"DQCce9TaDA"}],"visibility":"show","key":"TR9W9w8jmY"}],"key":"wWeo9Imc9A"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"User Inputs and File Handling","url":"/user-inputs-and-file-handling","group":"Essentials"},"next":{"title":"Basic visualizations","url":"/basic-visualizations","group":"Essentials"}}},"domain":"http://localhost:3001"}