rea to float\n                area = float(parts[2])\n                print(f\"Farm {farm_id} ({crop}): {area} ha\")\n            except ValueError:\n                print(f\"Warning: Invalid area for Farm {farm_id}\")\n\nexcept FileNotFoundError:\n    print(f\"Critical Error: The file '{target_file}' was not found.\")","visibility":"show","key":"XRRVBEebAQ"},{"type":"outputs","id":"RgPQ0mzHUPLrXtFczA2Tq","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Critical Error: The file 'missing_file.txt' was not found.\n"},"children":[],"key":"SkayucW1ZQ"}],"visibility":"hide","key":"eR6gEphb0y"}],"visibility":"show","key":"JX7HHDKggj"}],"key":"MdCWL91pGU"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"User Inputs and File Handling","url":"/user-inputs-and-file-handling","group":"Essentials"},"next":{"title":"Basic visualizations","url":"/basic-visualizations","group":"Essentials"}}},"domain":"http://localhost:3001"}