nError:\n        return \"Error: Cannot divide by zero (Hectares is 0)\"\n    except TypeError:\n        return \"Error: Inputs must be numbers\"\n\n# Test cases\nprint(calculate_yield(100, 10))  # Normal\nprint(calculate_yield(100, 0))   # Error: Division by Zero\nprint(calculate_yield(\"100\", 5)) # Error: Wrong Type","visibility":"show","key":"sMnOZ8sGSh"},{"type":"outputs","id":"wUXEY5guz5WI9PvhlI0tj","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"10.00 tons/ha\nError: Cannot divide by zero (Hectares is 0)\nError: Inputs must be numbers\n"},"children":[],"key":"iuNFZt5KsF"}],"visibility":"hide","key":"xmTgFqqRYO"}],"visibility":"show","key":"E9jLGpV5xK"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"File and Exception Handling Combined","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"I9PXTtQu80"}],"identifier":"file-and-exception-handling-combined","label":"File and Exception Handling Combined","html_id":"file-and-exception-handling-combined","implicit":true,"key":"qkGOUwPZYH"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Real-world data is messy. A file might be missing, or a user might enter “N/A” in a numeric column. We combine ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"exOAn3Lc6s"},{"type":"inlineCode","value":"with open","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"AlSu8lCtdz"},{"type":"text","value":" and ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"Akw6Zj6V31"},{"type":"inlineCode","value":"try-except","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"tGRBR9HzdI"},{"type":"text","value":" to build robust pipelines.","position":{"s