nError:\n        return \"Error: Cannot divide by zero (Hectares is 0)\"\n    except TypeError:\n        return \"Error: Inputs must be numbers\"\n\n# Test cases\nprint(calculate_yield(100, 10))  # Normal\nprint(calculate_yield(100, 0))   # Error: Division by Zero\nprint(calculate_yield(\"100\", 5)) # Error: Wrong Type","visibility":"show","key":"Y3pT5Vk050"},{"type":"outputs","id":"kBK6RzW19zxXVeH25mdsV","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"10.00 tons/ha\nError: Cannot divide by zero (Hectares is 0)\nError: Inputs must be numbers\n"},"children":[],"key":"UsXf74JwMe"}],"visibility":"hide","key":"tZr15HTfQI"}],"visibility":"show","key":"ZBDRe39Qip"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"File and Exception Handling Combined","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gr4nQFLIH0"}],"identifier":"file-and-exception-handling-combined","label":"File and Exception Handling Combined","html_id":"file-and-exception-handling-combined","implicit":true,"key":"CRwoJRmkQk"},{"type":"paragraph","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"children":[{"type":"text","value":"Real-world data is messy. A file might be missing, or a user might enter “N/A” in a numeric column. We combine ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"KO7MjqIhPl"},{"type":"inlineCode","value":"with open","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"GLxZqIcBuz"},{"type":"text","value":" and ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"isTEcqrilb"},{"type":"inlineCode","value":"try-except","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"tBe9GJg3so"},{"type":"text","value":" to build robust pipelines.","position":{"s