ype":"text","value":": We define a correct phone number is one that starts with +639 or 639 and contains 12 digits. Extract correct and incorrect phone numbers from a list.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"fTFR0B8oX5"}],"key":"Bd0K8fufbW"}],"visibility":"show","key":"OrmDPNMSDS"},{"type":"block","kind":"notebook-code","data":{"editable":true,"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import re\n\nphone_numbers = [\n    \"+639123456789\", \n    \"639987654321\", \n    \"+63987654320\", # 11 digits, should be removed\n    \"01234567890\",   # doesn't start with +639, should be removed\n    \"+63998876543241\", # invalid phone number (starts with incorrect length)\n]\n\n# Write your solution here","visibility":"show","key":"b4nI8Z5USE"},{"type":"outputs","id":"LNJgQ4Ft2LiK1Pa3Uzc0t","children":[],"visibility":"show","key":"nBMwLmy02c"}],"visibility":"show","key":"AsVTAcqCt4"},{"type":"block","kind":"notebook-code","data":{"collapsed":true,"editable":true,"jupyter":{"outputs_hidden":true,"source_hidden":true},"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# Solution\n# Regular expression to match a valid 12-digit phone number that starts with +63 or 63 and has the correct structure\npattern = r\"^\\+?63\\d{10}$\"\n\ncorrect_phone_numbers = list(filter(lambda x: re.match(pattern, x), phone_numbers))\nincorrect_phone_numbers = [number for number in phone_numbers if number not in correct_phone_numbers]\n\nprint(f\"Correct Phone Numbers: {correct_phone_numbers}\")\nprint(f\"Incorrect Phone Numbers: {incorrect_phone_numbers}\")\n# for num in filtered_phone_numbers:\n#     print(num)","visibility":"hide","key":"Dgx9zOnFKe"},{"type":"outputs","id":"oO5X5cOSHaRlYszRKi21m","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Correct Phone Numbers: ['+639123456789', 