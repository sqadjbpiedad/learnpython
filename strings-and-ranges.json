ype":"text","value":": We define a correct phone number is one that starts with +639 or 639 and contains 12 digits. Extract correct and incorrect phone numbers from a list.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Uxo83NQDf2"}],"key":"yp1kDVqWf1"}],"visibility":"show","key":"qqqmlMuDGL"},{"type":"block","kind":"notebook-code","data":{"editable":true,"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import re\n\nphone_numbers = [\n    \"+639123456789\", \n    \"639987654321\", \n    \"+63987654320\", # 11 digits, should be removed\n    \"01234567890\",   # doesn't start with +639, should be removed\n    \"+63998876543241\", # invalid phone number (starts with incorrect length)\n]\n\n# Write your solution here","visibility":"show","key":"dSf4s7l9vE"},{"type":"outputs","id":"_AIG2C2hTJg4e44TMqPns","children":[],"visibility":"show","key":"msbqSGxkvh"}],"visibility":"show","key":"ymjOIrhbhx"},{"type":"block","kind":"notebook-code","data":{"collapsed":true,"editable":true,"jupyter":{"outputs_hidden":true,"source_hidden":true},"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# Solution\n# Regular expression to match a valid 12-digit phone number that starts with +63 or 63 and has the correct structure\npattern = r\"^\\+?63\\d{10}$\"\n\ncorrect_phone_numbers = list(filter(lambda x: re.match(pattern, x), phone_numbers))\nincorrect_phone_numbers = [number for number in phone_numbers if number not in correct_phone_numbers]\n\nprint(f\"Correct Phone Numbers: {correct_phone_numbers}\")\nprint(f\"Incorrect Phone Numbers: {incorrect_phone_numbers}\")\n# for num in filtered_phone_numbers:\n#     print(num)","visibility":"hide","key":"ffqhG2k06v"},{"type":"outputs","id":"e1darHJQJVyhwlJXe4XyE","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Correct Phone Numbers: ['+639123456789', '639987654321']\nIncorrect Phone Numbers: ['+63987654320', '01234567890', '+63998876543241']\n"},"children":[],"key":"APdwFksBwa"}],"visibility":"show","key":"ztKO30Bszg"}],"visibility":"show","key":"f5SnTMJq4p"}],"key":"uN3VGrmdPm"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Lambda, Map, Filter","url":"/lambda-map-filter","group":"Essentials"},"next":{"title":"Loops and Conditionals","url":"/loops-and-conditionals","group":"Essentials"}}},"domain":"http://localhost:3000"}