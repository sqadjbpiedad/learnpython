:[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"The first capitalized word in is Hello THIS test a world is: Hello\nThe first capitalized word in is world Hello a test THIS is: Hello\nThe first capitalized word in world is Hello test a THIS is: Hello\nThe first capitalized word in THIS a world test is Hello is: THIS\nThe first capitalized word in is test a THIS Hello world is: THIS\n"},"children":[],"key":"EktyJpVJA5"}],"visibility":"show","key":"UTN7ukCuqm"}],"visibility":"show","key":"x0oi05K010"},{"type":"block","kind":"notebook-content","data":{"editable":true,"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Practice Exercises","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"vL5q0uOe7U"}],"identifier":"practice-exercises","label":"Practice Exercises","html_id":"practice-exercises","implicit":true,"key":"YQz8MkG1R8"}],"visibility":"show","key":"w7k9Wk1UfP"},{"type":"block","kind":"notebook-content","data":{"editable":true,"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Extract correct phone numbers","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ojijIwXA7Y"}],"identifier":"extract-correct-phone-numbers","label":"Extract correct phone numbers","html_id":"extract-correct-phone-numbers","implicit":true,"key":"fsIWhqxMxR"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Task","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"R7GFxGwM9P"}],"key":"sK8fpCOgOR"},{"type":"text","value":": We define a correct phone number is one that starts with +639 or 639 and contains 12 digits. Extract correct and incorrect phone numbers from a list.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"bPq9Cuda0r"}],"key":"kqhRkdVmY8"}],"visibility":"show","key":"CLniYgps31"},{"type":"block","kind":"notebook-code","data":{"editable":true,"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"import re\n\nphone_numbers = [\n    \"+639123456789\", \n    \"639987654321\", \n    \"+63987654320\", # 11 digits, should be removed\n    \"01234567890\",   # doesn't start with +639, should be removed\n    \"+63998876543241\", # invalid phone number (starts with incorrect length)\n]\n\n# Write your solution here","visibility":"show","key":"ria1UbGmcq"},{"type":"outputs","id":"ASiEwD_g0rckzys5YEJZa","children":[],"visibility":"show","key":"NCgngbXGi0"}],"visibility":"show","key":"zd1tGGdPhm"},{"type":"block","kind":"notebook-code","data":{"collapsed":true,"editable":true,"jupyter":{"outputs_hidden":true,"source_hidden":true},"slideshow":{"slide_type":""},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"# Solution\n# Regular expression to match a valid 12-digit phone number that starts with +63 or 63 and has the correct structure\npattern = r\"^\\+?63\\d{10}$\"\n\ncorrect_phone_numbers = list(filter(lambda x: re.match(pattern, x), phone_numbers))\nincorrect_phone_numbers = [number for number in phone_numbers if number not in correct_phone_numbers]\n\nprint(f\"Correct Phone Numbers: {correct_phone_numbers}\")\nprint(f\"Incorrect Phone Numbers: {incorrect_phone_numbers}\")\n# for num in filtered_phone_numbers:\n#     print(num)","visibility":"hide","key":"OjdpysqUjx"},{"type":"outputs","id":"Z2MEWDj05YTQ4je0DZaSG","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Correct Phone Numbers: ['+639123456789', '639987654321']\nIncorrect Phone Numbers: ['+63987654320', '01234567890', '+63998876543241']\n"},"children":[],"key":"MFgBpMTp7f"}],"visibility":"show","key":"GqtDewm0Qx"}],"visibility":"show","key":"c3TC0ikIlu"}],"key":"UsNHugFCsI"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Lambda, Map, Filter","url":"/lambda-map-filter","group":"Essentials"},"next":{"title":"Loops and Conditionals","url":"/loops-and-conditionals","group":"Essentials"}}},"domain":"http://localhost:3001"}