{"version":3,"kind":"Article","sha256":"36fda6a0417be76e449a0a10e1e378f125ad093812618362e8c3e6d06c423bee","slug":"why-python","location":"/01-Before-You-Begin/01-why-python.md","dependencies":[],"frontmatter":{"title":"Why you should still learn Python (in the age of vibe coding and LLMs)","description":"Foundational Python knowledge ensures you’re not just a user of tools—you’re a creator, capable of solving real-world problems with precision and control. While LLMs and 'vibe coding' tools may result in faster code generation, foundational knowledge of Python is still needed to debug and optimize AI-generated code.","numbering":{"title":{"offset":1}},"thumbnail":"/build/66235468dde4e0972070ae4d8c87c781.jpeg","exports":[{"format":"md","filename":"01-why-python.md","url":"/build/01-why-python-ad0c9522763bd3d8377d96886d77737e.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"While LLMs (especially generic ones) can produce functional Python snippets, they often lack context-specific nuances and could be full of bugs. Grasp of the language is still essential for customizing, debugging, and/or optimizing AI-generated code.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"bPh4uGNz3v"}],"key":"iHGlZWYquF"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"This is specially true if you are building large, complex, or production-ready solutions from scratch.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"keb1aUOY6y"}],"key":"Go5KDXJHpR"},{"type":"admonition","kind":"tip","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"MAINTAIN AUTONOMY OF YOUR CODE","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"CFPws4hDni"}],"key":"ynBgsvbWf6"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Foundational Python knowledge ensures ","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"ru0bTIpWMZ"},{"type":"strong","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"you are not just a user of tools","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"fjF6qBKYR2"}],"key":"iiUhewlYtm"},{"type":"text","value":"—you’re a creator, capable of solving real-world problems with precision and control.","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"YD61spiI8N"}],"key":"mckbEHQksO"}],"key":"oqgO4xx4VV"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"But can I still use LLMs/AI?","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"dQfiFN10H1"}],"identifier":"but-can-i-still-use-llms-ai","label":"But can I still use LLMs/AI?","html_id":"but-can-i-still-use-llms-ai","implicit":true,"key":"AMveiqJDJ6"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":17,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":17,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"In a way, yes. Just make sure that you are making this decision consciously and that you are aware of its limitations and downsides. Don’t take LLM/AI’s word as gospel.","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"XJBcXFpruf"}],"key":"cVt5ifqn4Q"}],"key":"tnnweqvevm"}],"key":"Fye7TE44OT"},{"type":"image","url":"/build/66235468dde4e0972070ae4d8c87c781.jpeg","alt":"A computer can never be held accountable","position":{"start":{"line":19,"column":1},"end